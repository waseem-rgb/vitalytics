# Vitalytics API — Environment Variables
# Copy to .env and fill in values

# Anthropic API key for Claude LLM calls
ANTHROPIC_API_KEY=sk-ant-...

# Path to Harrison's Principles of Internal Medicine PDF (for RAG ingestion)
HARRISON_PDF_PATH=/path/to/harrisons.pdf

# ChromaDB persistence directory
CHROMA_PERSIST_DIR=./data/chroma_db

# Allowed CORS origins (comma-separated)
# Default: http://localhost:3002,http://127.0.0.1:3002
CORS_ORIGINS=http://localhost:3002,http://127.0.0.1:3002
